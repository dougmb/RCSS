# ──────────────────────────────────────────────────────────────────────────────
# Configurações de Backup - RCSS
# ──────────────────────────────────────────────────────────────────────────────

# Diretório raiz onde os projetos salvam seus backups (ex: /opt/backups/MORACIA)
BACKUP_ROOT="/opt/backups"

# Nome do 'remote' configurado no rclone (ex: "drive:" ou "douglas:")
RCLONE_REMOTE="douglas:"

# Pasta de destino dentro do Google Drive (onde todos os projetos serão salvos)
# Ex: "Backups" criará uma pasta chamada Backups na raiz do seu Drive.
DRIVE_DESTINATION="Backups"

# RETENTION_DAYS
# Define quantos dias os backups ficam guardados LOCALMENTE no servidor.
# - Se definido como 7, arquivos com mais de 7 dias em /opt/backups/* serão DELETADOS.
# - Isso NÃO afeta os arquivos na nuvem (Google Drive).
RETENTION_DAYS=7

# REMOTE_RETENTION_DAYS
# Define quantos dias os backups ficam guardados na NUVEM (Google Drive).
# - Se definido como 15, arquivos com mais de 15 dias no Drive serão DELETADOS.
REMOTE_RETENTION_DAYS=15

# IGNORED_FOLDERS
# Lista de nomes de pastas (separadas por espaço) que devem ser ignoradas na raiz do BACKUP_ROOT.
# Estas pastas não serão tratadas como projetos de backup.
IGNORED_FOLDERS="scripts config bin logs lost+found"

# TRAVA DE SEGURANÇA (Limpeza Remota)
# O script de limpeza só rodará se encontrar ao menos um backup mais novo que X dias.
# Isso evita que o histórico seja apagado se os novos backups pararem de ser feitos.
REMOTE_CLEANUP_SAFETY_DAYS=2

# Caminho do arquivo de log (opcional). Se omitido, salva na pasta do script.
# LOG_FILE="/opt/backups/scripts/sync.log"
