# ──────────────────────────────────────────────────────────────────────────────
# Backup Configuration - RCSS
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Root directory containing the project backup folders (e.g.: /opt/backups/MYPROJECT)
BACKUP_ROOT="/opt/backups"

# rclone remote name as configured via `rclone config` (e.g.: "drive:" or "douglas:")
RCLONE_REMOTE="douglas:"

# ── Retention ─────────────────────────────────────────────────────────────────

# Days to keep backups LOCALLY. Files older than this are deleted after a successful upload.
RETENTION_DAYS=1

# Days to keep backups in the CLOUD (Google Drive). Does not affect local files.
REMOTE_RETENTION_DAYS=15

# DELETE_AFTER_UPLOAD
# If "true", local files are deleted immediately after a successful upload,
# regardless of RETENTION_DAYS. Default: "false".
DELETE_AFTER_UPLOAD="false"

# ── Cloud ─────────────────────────────────────────────────────────────────────

# Destination folder on Google Drive (created at the root of your Drive).
DRIVE_DESTINATION="Backups"

# REMOTE_CLEANUP_SAFETY_DAYS
# Remote cleanup (cleanRemoteBackups.sh) is blocked if no backup newer than
# this many days is found — prevents wiping history if uploads have stopped.
REMOTE_CLEANUP_SAFETY_DAYS=2

# ── Upload Behavior ───────────────────────────────────────────────────────────

# Folders inside BACKUP_ROOT to skip (space-separated). These are never treated as projects.
IGNORED_FOLDERS="scripts config bin logs lost+found"

# If "true", hidden files/folders (starting with .) are excluded from upload.
# Protects sensitive files like .env, .git/, .ssh/. Default: "false".
SKIP_DOTFILES="false"

# ── Logging ───────────────────────────────────────────────────────────────────

# Log file path. If omitted, defaults to the script directory (sync.log).
# LOG_FILE="/opt/backups/scripts/sync.log"
