# ──────────────────────────────────────────────────────────────────────────────
# Backup Configuration - RCSS
# ──────────────────────────────────────────────────────────────────────────────

# Root directory where projects save their backups (e.g.: /opt/backups/MYPROJECT)
BACKUP_ROOT="/opt/backups"

# Name of the remote configured in rclone (e.g.: "drive:" or "douglas:")
RCLONE_REMOTE="douglas:"

# Destination folder inside Google Drive (where all projects will be saved)
# e.g.: "Backups" will create a folder called Backups at the root of your Drive.
DRIVE_DESTINATION="Backups"

# RETENTION_DAYS
# Defines how many days backups are kept LOCALLY on the server.
# - If set to 7, files older than 7 days in /opt/backups/* will be DELETED.
# - This does NOT affect cloud (Google Drive) files.
RETENTION_DAYS=1

# REMOTE_RETENTION_DAYS
# Defines how many days backups are kept in the CLOUD (Google Drive).
# - If set to 15, files older than 15 days on Drive will be DELETED.
REMOTE_RETENTION_DAYS=15

# IGNORED_FOLDERS
# List of folder names (space-separated) to ignore in the BACKUP_ROOT.
# These folders will not be treated as backup projects.
IGNORED_FOLDERS="scripts config bin logs lost+found"

# SKIP_DOTFILES
# If set to "true" (default), hidden files and folders (starting with .)
# inside each project will be excluded from upload.
# Set to "false" to include dotfiles in the backup.
SKIP_DOTFILES="true"

# SAFETY LOCK (Remote Cleanup)
# The cleanup script will only run if it finds at least one backup newer than X days.
# This prevents history from being erased if new backups stop being created.
REMOTE_CLEANUP_SAFETY_DAYS=2

# Log file path (optional). If omitted, saves to the script directory.
# LOG_FILE="/opt/backups/scripts/sync.log"
